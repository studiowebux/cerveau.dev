{
  "additionalDirectories": [
    "__BRAIN_DIR__"
  ],
  "deny": [
    "Read: **/.env*",
    "Read: **/.zshrc",
    "Read: **/.bashrc",
    "Read: **/.bash_profile",
    "Read: **/.zprofile",
    "Read: **/.netrc",
    "Read: **/.ssh/**",
    "Read: **/*.pem",
    "Read: **/*.key",
    "Read: **/*.secret*",
    "Edit: **/.env*",
    "Edit: **/.zshrc",
    "Edit: **/.bashrc",
    "Edit: **/.bash_profile",
    "Edit: **/.zprofile",
    "Edit: **/.netrc",
    "Edit: **/.ssh/**",
    "Edit: **/*.pem",
    "Edit: **/*.key",
    "Edit: **/*.secret*",
    "Write: **/.env*",
    "Write: **/.zshrc",
    "Write: **/.bashrc",
    "Write: **/.bash_profile",
    "Write: **/.zprofile",
    "Write: **/.netrc",
    "Write: **/.ssh/**",
    "Write: **/*.pem",
    "Write: **/*.key",
    "Write: **/*.secret*"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading brain context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact-handoff.sh",
            "timeout": 10,
            "statusMessage": "Saving handoff context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/commit-validator.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-reminder.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/checkpoint-counter.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-progress-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
