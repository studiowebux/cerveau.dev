# MCP token — required for Claude Code brains to connect via MCP.
# Any random string or UUID. Example: openssl rand -hex 32
MDPLANNER_MCP_TOKEN=

# Path to brains.json inside the container — enables the Brain Manager UI.
# The cerveau.dev root is mounted at /cerveau in compose.yml.
MDPLANNER_BRAINS_CONFIG=/cerveau/_configs_/brains.json

# SQLite cache for fast full-text search (FTS5).
# Any non-empty value enables it. Creates .mdplanner.db in the data directory.
# Leave empty to disable (markdown files are still the source of truth).
MDPLANNER_CACHE=1

# Read-only mode — blocks all mutations via API and UI.
# Any non-empty value enables it. Leave empty for read-write.
MDPLANNER_READ_ONLY=

# WebDAV file access — edit markdown files with external editors (Obsidian, nvim, etc.).
# 1 = enabled, empty = disabled.
MDPLANNER_WEBDAV=1
MDPLANNER_WEBDAV_USER=
MDPLANNER_WEBDAV_PASS=

# Encryption key for integration secrets (e.g. Cloudflare API token stored in project.md).
# Generate with: docker exec <container> deno run --allow-all main.ts keygen-secret
# 32-byte hex string (64 hex chars). Leave empty to store tokens in plaintext.
MDPLANNER_SECRET_KEY=

# Backup output directory inside the container.
# Must match a mounted volume to persist outside the container.
MDPLANNER_BACKUP_DIR=/backups

# Backup schedule interval in hours. Examples: 24 (daily), 168 (weekly).
# Leave empty to disable scheduled backups.
MDPLANNER_BACKUP_INTERVAL=

# RSA-OAEP-4096 public key (hex) for encrypted backups.
# Generate keypair with: docker exec <container> deno run --allow-all main.ts keygen
# Store only the PUBLIC key here. Keep the private key offline.
# MDPLANNER_BACKUP_PUBLIC_KEY=
